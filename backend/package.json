{
  "name": "backend",
  "version": "1.0.1",
  "description": "Lastik Depo Takip Sistemi",
  "main": "main.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:electron": "electron .",
    "build:exe": "electron-builder --win -p never",
    "build:mac": "electron-builder --mac --universal -c.mac.identity=null -p never"
  },
  "author": "Tahakrcc",
  "build": {
    "appId": "com.capraz.stok",
    "productName": "Stok Yonetimi",
    "directories": {
      "output": "../dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stok Yonetimi"
    },
    "files": [
      "**/*",
      "../frontend-demo/**/*",
      ".env",
      "!node_modules/sqlite3",
      "!node_modules/pkg"
    ]
  },
  "keywords": [],
  "repository": "tahakrcc/lastik-depo-takip-sistemi",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^42.5.1",
    "electron-builder": "24.13.3",
    "wait-on": "^9.0.10"
  }
}
